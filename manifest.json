{
  "manifest_version": 3,
  "name": "Santuario",
  "version": "2.5.3",
  "description": "A fully custom privacy-focused new tab dashboard.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "storage",
    "identity",
    "unlimitedStorage"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "host_permissions": [
    "https://api.openweathermap.org/*",
    "https://api.spotify.com/*",
    "https://accounts.spotify.com/*"
  ]
}